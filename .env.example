# Supabase (auto-injected by Supabase Vercel Integration, or set manually)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-publishable-api-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe (from Stripe Dashboard > Developers > API keys)
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Resend (from resend.com > API Keys)
RESEND_API_KEY=re_...
CRON_SECRET=your-cron-secret
RESEND_FROM=onboarding@resend.dev

# API Key Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_SECRET=your-64-char-hex-key

# Auto-migration (auto-injected by Supabase Vercel Integration)
# POSTGRES_URL_NON_POOLING=postgresql://...

# AI image generation via fal.ai (optional -- SVG placeholders used if absent)
# FAL_KEY=your-fal-api-key

# x402 Solana micropayments
# X402_MERCHANT_WALLET=your-solana-wallet-address
# SOL_USD_RATE=150
# SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Tavily Search API — fallback search for LLMs without built-in search
# (Claude, DeepSeek, MiniMax, Qwen). OpenAI and Gemini use their own.
TAVILY_API_KEY=tvly-...

# LLM APIs — user-supplied keys stored per-user in database
# No platform-level LLM key needed. Set during deployment if platform-level defaults are desired.
